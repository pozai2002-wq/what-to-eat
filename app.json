{
  "expo": {
    "name": "What to Eat",
    "slug": "what-to-eat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "whattoeat",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#13131A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.whattoeat.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to find restaurants near you."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#13131A",
        "foregroundImage": "./assets/images/icon.png"
      },
      "package": "com.whattoeat.app",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sharing",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "We need your location to find restaurants near you."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
